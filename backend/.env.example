# Supabase Configuration
# Get these from: Supabase Dashboard -> Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis Cache (Upstash) - RECOMMENDED: Use REST API
# Get from: console.upstash.com -> Your Database -> REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alternative: TCP connection (ioredis) - requires TLS (rediss://)
# REDIS_URL=rediss://default:xxx@ap-south-1-xxx.upstash.io:6379

# Server Port (Railway sets this automatically)
PORT=3001

# OpenAI API Key
OPENAI_API_KEY=

# Facebook/Meta App Credentials (for WhatsApp)
# Get from: developers.facebook.com -> Your App -> Settings -> Basic
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Twilio (per-phone-number, stored encrypted in DB — also used for direct env config)
# TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN are stored per phone number in DB

# Paddle (payments)
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_ENVIRONMENT=production
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=

# Stripe (legacy — Paddle is primary)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (legacy — Paddle is primary)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Backend URL (used by dialer webhooks)
BACKEND_URL=
FRONTEND_URL=

# Security
ENCRYPTION_KEY=
OAUTH_STATE_SECRET=
ADMIN_PASSKEY=

# Google OAuth (for calendar integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CRM Integrations
LIONDESK_CLIENT_ID=
LIONDESK_CLIENT_SECRET=
FUB_SYSTEM_KEY=

# Voice Agent (optional override)
VOICE_AGENT_URL=

# Daily.co (video calls, if used)
DAILY_API_KEY=
